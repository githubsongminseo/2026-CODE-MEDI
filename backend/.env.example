# OpenAI 공식 API 키. platform.openai.com 에서 발급
OPENAI_API_KEY=여기에_실제_키를_붙여넣으세요

# 대화 생성용 모델 — 환자 역할 응답을 매 턴 생성하므로 가볍고 빠른 모델 권장
OPENAI_MODEL_CHAT=gpt-4o-mini

# 평가용 모델 — 체크리스트/PPI 판정은 더 정교한 추론이 필요해서 무거운 모델 권장
OPENAI_MODEL_EVAL=gpt-4o

# 본인 계정에서 사용 가능한 모델명으로 위 두 값을 바꿔서 사용하세요.
# 모델 목록/가격: https://platform.openai.com/docs/models
